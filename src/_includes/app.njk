<!DOCTYPE html>
<html lang="uk">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="{{ '/assets/favicon.svg' | url }}">

    import app_meta

    <link rel="stylesheet" href="{{ '/assets/style.css' | url }}" />
  </head>

  <body>
    <header class="header">
      <div class="container">
        <div class="header-content">
          <a
            href="{{ site.routes.home | url }}"
            aria-label="Повернутись на домашню сторінку"
            class="logo-link"
          >
            <div class="logo">
              <p class="logo-title">{{ site.org.name }}</p>
              <p class="logo-tagline">{{ site.org.tagline }}</p>
            </div>
          </a>

          <button
            class="nav-burger"
            type="button"
            aria-expanded="false"
            aria-controls="main-nav"
            aria-label="Відкрити меню"
          >
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
          </button>

          <nav class="nav" aria-label="Головна навігація">
            <ul class="nav-list" id="main-nav">
              {% for navigation in site.navigation.items %}
              <li>
                <a href="{{ navigation.url | url }}">{{ navigation.title }}</a>
              </li>
              {% endfor %}
            </ul>
          </nav>
        </div>
      </div>
    </header>

    <main>{{ content | safe }}</main>

    <footer class="footer">
      <div class="container">
        <div class="footer-content">
          <div class="footer-section">
            <h3>{{ site.org.name }}</h3>
            <p>{{ site.org.description }}</p>
          </div>

          <div class="footer-section">
            <h3>Контакти</h3>
            <p>
              Телефон:
              <a href="tel:{{ site.org.phone }}">{{ site.org.phone }}</a>
            </p>
            <p>
              Email:
              <a href="mailto:{{ site.org.email }}">{{ site.org.email }}</a>
            </p>
            <p>{{ site.org.address }}</p>
            <p>{{ site.org.hours }}</p>
          </div>

          <div class="footer-section">
            <h3>Навігація</h3>
            <nav aria-label="Футер навігація">
              <ul class="footer-nav-list">
                {% for navigation in site.navigation.items %}
                <li>
                  <a href="{{ navigation.url | url }}"
                    >{{ navigation.title }}</a
                  >
                </li>
                {% endfor %}
                <li>
                  <a href="{{ site.routes.admin | url }}">Адміністратору</a>
                </li>
              </ul>
            </nav>
          </div>
        </div>

        <div class="footer-bottom">
          <p>&copy; 2026 | З повагою, {{ site.org.name }}!</p>
        </div>
      </div>
    </footer>

    <script src="{{ '/assets/script.js' | url }}" defer></script>
  </body>
</html>
