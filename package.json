{
  "name": "kp-web",
  "version": "0.0.0",
  "description": "",
  "scripts": {
    "clean": "node -e \"fs.rmSync('_site', { recursive: true, force: true })\"",
    "format": "prettier --write **/*.{js,json,css,md,html}",
    "start": "npm run clean && eleventy --serve",
    "start:prod": "npm run clean && npm run build-ghpages && eleventy-dev-server --dir=_site",
    "build-ghpages": "eleventy --pathprefix=/kp-web/"
  },
  "keywords": [],
  "author": "",
  "license": "",
  "type": "module",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "11ty.ts": "^0.0.7",
    "husky": "^9.1.7",
    "prettier": "3.8.3"
  }
}
